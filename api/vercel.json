{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    },
    {
      "src": "/api/leads",
      "dest": "/api/leads.js"
    },
    {
      "src": "/api/messages",
      "dest": "/api/messages.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "JWT_SECRET": "isis-crm-prod-secret-2026-mude-isto-agora",
    "ALLOWED_ORIGINS": "*"
  }
}
