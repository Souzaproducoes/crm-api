{
    "version": 2,
    "builds": [
        {
            "src": "api/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/login",
            "dest": "/api/login.js"
        },
        {
            "src": "/api/register",
            "dest": "/api/register.js"
        },
        {
            "src": "/api/auth-me",
            "dest": "/api/auth-me.js"
        },
        {
            "src": "/api/logout",
            "dest": "/api/logout.js"
        },
        {
            "src": "/api/leads",
            "dest": "/api/leads.js"
        },
        {
            "src": "/api/messages",
            "dest": "/api/messages.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}